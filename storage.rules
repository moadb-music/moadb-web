rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Comprovantes de membros — só o dono faz upload, autenticados leem
    match /member-proofs/{uid}/{file} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read:  if request.auth != null;
    }

    // Conteúdo exclusivo — só admin faz upload (autenticado), membros leem
    match /members-content/{file} {
      allow write: if request.auth != null;
      allow read:  if request.auth != null;
    }

    match /members-content/thumbs/{file} {
      allow write: if request.auth != null;
      allow read:  if request.auth != null;
    }
  }
}
