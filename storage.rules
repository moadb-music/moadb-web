rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Comprovantes de membros — só o dono faz upload, autenticados leem
    match /member-proofs/{uid}/{file} {
      allow write: if request.auth != null && request.auth.uid == uid;
      allow read:  if request.auth != null;
    }

    // Conteúdo exclusivo de membros — autenticados leem e listam, escrevem
    match /members-content/{allPaths=**} {
      allow read, list: if request.auth != null;
      allow write:      if request.auth != null;
    }

    // Imagens gerais do site (galeria do admin)
    match /images/{allPaths=**} {
      allow read, list: if request.auth != null;
      allow write:      if request.auth != null;
    }

    // Outras pastas do admin (covers, etc.)
    match /{folder}/{allPaths=**} {
      allow read, list: if request.auth != null;
      allow write:      if request.auth != null;
    }
  }
}
